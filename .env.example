APP_URL=https://your-domain.com

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_FALLBACK_MODEL=gpt-4o-mini
OPENAI_MAX_RETRIES=3
PAYSTACK_SECRET_KEY=your_paystack_secret_key_here

MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=info@syitech.com.ng
MAIL_PASSWORD=your_hostinger_smtp_password
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=info@syitech.com.ng
MAIL_FROM_NAME=SYiTech
MAIL_TIMEOUT=30

AI_DOWNLOAD_EXPIRY_DAYS=14
AI_WORKER_SECRET=change_this_to_a_long_random_string
